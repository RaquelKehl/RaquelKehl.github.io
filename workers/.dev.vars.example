# Local development secrets for `npx wrangler dev`.
# Copy to .dev.vars (gitignored) and fill in real values.

# preferred contact relay — access key from https://web3forms.com
WEB3FORMS_KEY="REPLACE_ME"

# legacy alternative, used only when WEB3FORMS_KEY is absent
FORMSPREE_ENDPOINT=""

WEBHOOK_SECRET="use-a-long-random-string-here"
GITHUB_TOKEN=""
