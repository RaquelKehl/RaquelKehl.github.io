# ═══════════════════════════════════════════════════════════════
# Environment template — copy to .env (gitignored) and fill in.
# Nothing in this file is read by the static site; these values are
# used by the CrewAI pipeline (later batch) and CI.
# ═══════════════════════════════════════════════════════════════

# --- CrewAI agent pipeline (GitHub Secrets in CI) ---
# LLM provider key for the agent crew
OPENAI_API_KEY=""

# Shared HMAC secret — must equal the Worker's WEBHOOK_SECRET
WEBHOOK_SECRET=""

# Worker base URL, e.g. https://portfolio-api.<subdomain>.workers.dev
WORKER_BASE_URL=""

# --- optional ---
# Raises GitHub API rate limits for the Worker (read-only public scope)
GITHUB_TOKEN=""
